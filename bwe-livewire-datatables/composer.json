{
    "name": "vendor/bwe-livewire-datatables",
    "description": "Reusable Livewire datatable package for Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "BweLivewireDatatables\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Pratibha"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "livewire/livewire": "^4.3"
    },
    "extra": {
        "laravel": {
            "providers": [
                "BweLivewireDatatables\\DataTableServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}